# PostgreSQL
POSTGRES_DB=pottenbakkerij
POSTGRES_USER=pottenbakker
POSTGRES_PASSWORD=pottenbakker_dev_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django
DJANGO_ENV=local
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql://pottenbakker:pottenbakker_dev_password@db:5432/pottenbakkerij

# E-mail (booking confirmations)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@pottenbakkerijgrolle.nl
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=0
EMAIL_USE_SSL=0
BOOKING_CONFIRMATION_EMAIL_ENABLED=1
BOOKING_CONFIRMATION_BCC=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
